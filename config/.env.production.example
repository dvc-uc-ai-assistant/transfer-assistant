# Production Environment Variables (for Cloud Run)
# DO NOT commit actual values - use Cloud Run environment variables instead

# OpenAI API
OPENAI_API_KEY=sk-your-actual-key-here

# Cloud SQL Connection (Unix Socket - recommended)
DATABASE_URL=postgresql://transfer_user:STRONG_PASSWORD@/transfer_assistant_db?host=/cloudsql/PROJECT-ID:us-central1:transfer-assistant-db

# Alternative: Cloud SQL with TCP (if using proxy)
# DATABASE_URL=postgresql://transfer_user:STRONG_PASSWORD@127.0.0.1:5432/transfer_assistant_db

# Flask/Logging
FLASK_ENV=production
LOG_FOLDER=/tmp/logs

# Cloud Run specific
PORT=8080
